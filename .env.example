DATABASE_URL="postgresql://postgres:postgres@localhost:5432/duelmasters_classic08"

# --- チャットLLMプロバイダ ---
# ollama (既定 / ローカル) / gemini (Google Gemini) / groq (Groq, 無料枠は課金設定不要)
CHAT_PROVIDER="groq"

# CHAT_PROVIDER=groq のとき必須。console.groq.com で発行する無料APIキー。
GROQ_API_KEY=""
# 任意。既定 llama-3.3-70b-versatile（速度優先なら llama-3.1-8b-instant 等）
GROQ_MODEL="llama-3.3-70b-versatile"
# 任意。1回答の最大生成トークン数。既定 512
GROQ_MAX_TOKENS="512"

# CHAT_PROVIDER=gemini のとき必須。Google AI Studio (aistudio.google.com) の AIza... キー。
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.0-flash"
GEMINI_MAX_TOKENS="512"

# サーバ待受ポート。Render等PaaSは PORT を自動注入するので未設定でよい。ローカル既定 8788。
# CHAT_PORT="8788"

# --- Web検索フォールバック（任意） ---
# DB(クラシック08)に該当が無い質問のとき Web検索して回答する。未設定なら「情報がありません」で打ち止め。
# tavily.com で発行する無料APIキー（無料枠あり）。
TAVILY_API_KEY=""
# 任意。検索結果の最大件数。既定 5
SEARCH_MAX_RESULTS="5"

# --- アクセス解析（Google Analytics 4, 任意） ---
# GA4測定ID（G-XXXXXXXXXX）。設定して `npm run build:analytics-config` を実行すると
# public/js/analytics-config.js が生成され、同意後にGA4計測が有効になる。
# 未設定なら計測は完全に無効（バナーも出ない）。IDはソースに直書きせずここ/CI変数から注入する。
GA_MEASUREMENT_ID=""
